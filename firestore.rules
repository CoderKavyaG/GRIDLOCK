rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['banned', 'isAdmin', 'role']);
      allow delete: if request.auth != null && request.auth.token.get('role') == 'admin';
    }

    // Reviews collection - with approval workflow
    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true || request.auth != null && request.auth.token.get('role') == 'admin';
      allow create: if request.auth != null;
      allow update: if (request.auth != null && request.auth.uid == resource.data.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved'])) ||
                       (request.auth != null && request.auth.token.get('role') == 'admin');
      allow delete: if request.auth != null && (request.auth.uid == resource.data.uid || request.auth.token.get('role') == 'admin');
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      }
    }

    // Debates collection - with approval workflow
    match /debates/{debateId} {
      allow read: if (resource.data.approved == true) || 
                     (request.auth != null && request.auth.uid == resource.data.creatorId) ||
                     (request.auth != null && request.auth.token.get('role') == 'admin');
      allow create: if request.auth != null;
      allow update: if (request.auth != null && request.auth.uid == resource.data.creatorId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved', 'creatorId'])) ||
                       (request.auth != null && request.auth.token.get('role') == 'admin');
      allow delete: if request.auth != null && (request.auth.uid == resource.data.creatorId || request.auth.token.get('role') == 'admin');
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      }
    }

    // Collections collection
    match /collections/{collectionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Follows collection
    match /follows/{followId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.followerId;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }

    // Reports collection
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.get('role') == 'admin';
      allow update, delete: if request.auth != null && request.auth.token.get('role') == 'admin';
    }

    // Audit log
    match /audit/{entryId} {
      allow read, write: if request.auth != null && request.auth.token.get('role') == 'admin';
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.get('role') == 'admin';
    }

    // Votes collection
    match /votes/{voteId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Admin Pending Items (for approval queue)
    match /adminQueue/{itemId} {
      allow read, write: if request.auth != null && request.auth.token.get('role') == 'admin';
    }

    // Game shelf
    match /gameShelf/{userId}/games/{gameId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}